# Maintainer: JBetchGH <JBetchGH@users.noreply.github.com>
#
# Binary AUR package. Downloads the signed release artifacts directly
# from GitHub Releases — faster install, no Go toolchain required.
# Use the source `meshtermd` package if you'd rather build from
# verified source.
#
# Per-arch sources are matched at install time by makepkg; the
# sha256sums_<arch> arrays are regenerated by `make aur-prep` after
# every upstream tag.

pkgname=meshtermd-bin
pkgver=0.3.1
pkgrel=1
pkgdesc="Persistent terminal daemon over QUIC — mosh+tmux in one daemon, with multi-client handoff (pre-built)"
arch=('x86_64' 'aarch64' 'armv7h')
url="https://github.com/AG-Studio-Apps/meshtermd"
license=('Apache')
conflicts=('meshtermd')
provides=("meshtermd=${pkgver}" "mtctl=${pkgver}")

_releaseurl="https://github.com/AG-Studio-Apps/meshtermd/releases/download/v${pkgver}"

source_x86_64=(
    "${_releaseurl}/meshtermd-linux-amd64"
    "${_releaseurl}/mtctl-linux-amd64"
    "${_releaseurl}/SHA256SUMS"
    "${_releaseurl}/SHA256SUMS.minisig"
    "${_releaseurl}/meshtermd.8"
    "${_releaseurl}/mtctl.1"
    "${_releaseurl}/meshtermd.bash"
    "${_releaseurl}/mtctl.bash"
    "${_releaseurl}/meshtermd.zsh"
    "${_releaseurl}/mtctl.zsh"
    "${_releaseurl}/meshtermd.fish"
    "${_releaseurl}/mtctl.fish"
)
source_aarch64=(
    "${_releaseurl}/meshtermd-linux-arm64"
    "${_releaseurl}/mtctl-linux-arm64"
    "${_releaseurl}/SHA256SUMS"
    "${_releaseurl}/SHA256SUMS.minisig"
    "${_releaseurl}/meshtermd.8"
    "${_releaseurl}/mtctl.1"
    "${_releaseurl}/meshtermd.bash"
    "${_releaseurl}/mtctl.bash"
    "${_releaseurl}/meshtermd.zsh"
    "${_releaseurl}/mtctl.zsh"
    "${_releaseurl}/meshtermd.fish"
    "${_releaseurl}/mtctl.fish"
)
source_armv7h=(
    "${_releaseurl}/meshtermd-linux-armv7"
    "${_releaseurl}/mtctl-linux-armv7"
    "${_releaseurl}/SHA256SUMS"
    "${_releaseurl}/SHA256SUMS.minisig"
    "${_releaseurl}/meshtermd.8"
    "${_releaseurl}/mtctl.1"
    "${_releaseurl}/meshtermd.bash"
    "${_releaseurl}/mtctl.bash"
    "${_releaseurl}/meshtermd.zsh"
    "${_releaseurl}/mtctl.zsh"
    "${_releaseurl}/meshtermd.fish"
    "${_releaseurl}/mtctl.fish"
)

# Placeholder sums; `make aur-prep` rewrites these from the published
# SHA256SUMS after every upstream release. Do NOT publish the
# PKGBUILD with SKIP — defeats the point of per-arch hashes.
sha256sums_x86_64=(
    'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)
sha256sums_aarch64=(
    'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)
sha256sums_armv7h=(
    'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP'
)

# Optional but recommended: minisign-verify the signed manifest
# before makepkg trusts any of these files. Users with `minisign`
# installed can run `minisign -V -p docs/release-public-key.txt -m
# SHA256SUMS` against the public key shipped in the upstream repo.

prepare() {
    case "$CARCH" in
        x86_64)  _arch=linux-amd64 ;;
        aarch64) _arch=linux-arm64 ;;
        armv7h)  _arch=linux-armv7 ;;
    esac
    # Match the upstream binary name (no -linux-* suffix once installed).
    cp "${srcdir}/meshtermd-${_arch}" "${srcdir}/meshtermd"
    cp "${srcdir}/mtctl-${_arch}"     "${srcdir}/mtctl"
}

package() {
    install -Dm755 "${srcdir}/meshtermd" "${pkgdir}/usr/bin/meshtermd"
    install -Dm755 "${srcdir}/mtctl"     "${pkgdir}/usr/bin/mtctl"

    # systemd-user unit, generated from the freshly-installed binary
    # so the file always matches `meshtermd unit print`. KillMode=
    # process is load-bearing for the v0.6+ sidecar architecture.
    chmod +x "${srcdir}/meshtermd"
    "${srcdir}/meshtermd" unit print --bin=/usr/bin/meshtermd > "${srcdir}/meshtermd.service"
    install -Dm644 "${srcdir}/meshtermd.service" "${pkgdir}/usr/lib/systemd/user/meshtermd.service"

    install -Dm644 "${srcdir}/meshtermd.8" "${pkgdir}/usr/share/man/man8/meshtermd.8"
    install -Dm644 "${srcdir}/mtctl.1"     "${pkgdir}/usr/share/man/man1/mtctl.1"

    install -Dm644 "${srcdir}/meshtermd.bash" "${pkgdir}/usr/share/bash-completion/completions/meshtermd"
    install -Dm644 "${srcdir}/mtctl.bash"     "${pkgdir}/usr/share/bash-completion/completions/mtctl"
    install -Dm644 "${srcdir}/meshtermd.zsh"  "${pkgdir}/usr/share/zsh/site-functions/_meshtermd"
    install -Dm644 "${srcdir}/mtctl.zsh"      "${pkgdir}/usr/share/zsh/site-functions/_mtctl"
    install -Dm644 "${srcdir}/meshtermd.fish" "${pkgdir}/usr/share/fish/vendor_completions.d/meshtermd.fish"
    install -Dm644 "${srcdir}/mtctl.fish"     "${pkgdir}/usr/share/fish/vendor_completions.d/mtctl.fish"
}
