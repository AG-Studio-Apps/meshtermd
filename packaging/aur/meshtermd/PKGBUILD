# Maintainer: JBetchGH <JBetchGH@users.noreply.github.com>
#
# Build-from-source AUR package. Mirrors the `make all && make manpages
# && make completions` flow exactly; produces both meshtermd and mtctl
# in a single pkg.
#
# Pre-1.0: pkgver tracks the upstream git tag. Bump pkgrel when only
# this PKGBUILD changes (packaging fix, layout tweak); bump pkgver for
# upstream releases.

pkgname=meshtermd
pkgver=0.3.1
pkgrel=1
pkgdesc="Persistent terminal daemon over QUIC — mosh+tmux in one daemon, with multi-client handoff"
arch=('x86_64' 'aarch64' 'armv7h')
url="https://github.com/AG-Studio-Apps/meshtermd"
license=('Apache')
makedepends=('go>=1.26' 'git' 'pandoc')
conflicts=('meshtermd-bin')
provides=("meshtermd=${pkgver}" "mtctl=${pkgver}")
source=("git+https://github.com/AG-Studio-Apps/meshtermd.git#tag=v${pkgver}")
sha256sums=('SKIP')  # git tag; integrity rests on the tag's signature when present

build() {
    cd "${srcdir}/${pkgname}"
    make build build-mtctl manpages completions
}

check() {
    cd "${srcdir}/${pkgname}"
    make test
}

package() {
    cd "${srcdir}/${pkgname}"

    install -Dm755 meshtermd "${pkgdir}/usr/bin/meshtermd"
    install -Dm755 mtctl     "${pkgdir}/usr/bin/mtctl"

    # systemd-user unit. Generated from the daemon binary itself so
    # the file always matches what `meshtermd unit print` emits —
    # avoids drift between this PKGBUILD and the in-tree template.
    # Lands under /usr/lib/systemd/user/ where systemd-user finds
    # vendor-shipped units; an `ExecStart=%h/.local/bin/meshtermd` is
    # rewritten to `/usr/bin/meshtermd` for the distro install path.
    ./meshtermd unit print --bin=/usr/bin/meshtermd > meshtermd.service
    install -Dm644 meshtermd.service "${pkgdir}/usr/lib/systemd/user/meshtermd.service"

    # Man pages.
    install -Dm644 dist/man/meshtermd.8 "${pkgdir}/usr/share/man/man8/meshtermd.8"
    install -Dm644 dist/man/mtctl.1     "${pkgdir}/usr/share/man/man1/mtctl.1"

    # Shell completions.
    install -Dm644 dist/completions/meshtermd.bash "${pkgdir}/usr/share/bash-completion/completions/meshtermd"
    install -Dm644 dist/completions/mtctl.bash     "${pkgdir}/usr/share/bash-completion/completions/mtctl"
    install -Dm644 dist/completions/meshtermd.zsh  "${pkgdir}/usr/share/zsh/site-functions/_meshtermd"
    install -Dm644 dist/completions/mtctl.zsh      "${pkgdir}/usr/share/zsh/site-functions/_mtctl"
    install -Dm644 dist/completions/meshtermd.fish "${pkgdir}/usr/share/fish/vendor_completions.d/meshtermd.fish"
    install -Dm644 dist/completions/mtctl.fish     "${pkgdir}/usr/share/fish/vendor_completions.d/mtctl.fish"

    # Documentation.
    install -Dm644 README.md           "${pkgdir}/usr/share/doc/${pkgname}/README.md"
    install -Dm644 docs/SECURITY.md    "${pkgdir}/usr/share/doc/${pkgname}/SECURITY.md"
    install -Dm644 docs/mtctl.md       "${pkgdir}/usr/share/doc/${pkgname}/mtctl.md"
    install -Dm644 docs/roam-protocol.md "${pkgdir}/usr/share/doc/${pkgname}/roam-protocol.md"

    # License.
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
    install -Dm644 NOTICE  "${pkgdir}/usr/share/licenses/${pkgname}/NOTICE"
}
