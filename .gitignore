# Binaries — root-anchored so we don't accidentally ignore directories
# like cmd/meshtermd. The bare "meshtermd" pattern would match anywhere
# in the tree; "/meshtermd" matches only the build artifact at the root.
/meshtermd
/meshtermd-*
/dist/
/build/
/out/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Local cert / state directories used during dev
.local-state/
testdata/keys/
